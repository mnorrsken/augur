# Python RL agent image.
# Supports both training (with GPU) and gRPC serving.

FROM python:3.12-slim

WORKDIR /app

COPY agent/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY agent/ .
COPY proto/ /app/proto/

# Generate Python proto stubs at build time.
RUN python -m grpc_tools.protoc \
    -Iproto \
    --python_out=. \
    --grpc_python_out=. \
    proto/augur.proto

EXPOSE 50051

# Default entrypoint is serving; override with train.py for training.
ENTRYPOINT ["python"]
CMD ["serve.py"]
